# === comfyui-chroma : Chroma1-HD (uncensored, Apache-2.0) — endpoint dedie leger ===
FROM runpod/worker-comfyui:5.8.6-base
RUN wget -q -O /comfyui/models/diffusion_models/Chroma1-HD.safetensors \
    "https://huggingface.co/Comfy-Org/Chroma1-HD_repackaged/resolve/main/split_files/diffusion_models/Chroma1-HD-fp8mixed.safetensors"
RUN wget -q -O /comfyui/models/text_encoders/t5xxl_fp8_e4m3fn_scaled.safetensors \
    "https://huggingface.co/comfyanonymous/flux_text_encoders/resolve/main/t5xxl_fp8_e4m3fn_scaled.safetensors"
RUN wget -q -O /comfyui/models/vae/ae.safetensors \
    "https://huggingface.co/lodestones/Chroma1-HD/resolve/main/vae/diffusion_pytorch_model.safetensors"
